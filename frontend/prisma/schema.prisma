generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Company {
  id          String       @id @default(uuid())
  name        String       @unique
  logoUrl     String?
  users       User[]       @relation("CompanyUsers")
  jobPostings JobPosting[] @relation("CompanyJobs")
  hrSettings  HRSettings?  @relation("CompanySettings")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String
  fullName     String
  avatarUrl    String?

  // Profil Alanları
  tcKimlikNo        String?
  phone             String?
  address           String?
  dateOfBirth       DateTime?
  isProfileComplete Boolean       @default(false)

  // Enum values stored as String: "SUPER_ADMIN", "HR", "CANDIDATE"
  role         String        @default("CANDIDATE")
  companyId    String?
  company      Company?      @relation("CompanyUsers", fields: [companyId], references: [id], onDelete: SetNull)
  theme        String        @default("theme-1")
  
  applications Application[] @relation("CandidateApplications")

  // Yeni Profil İlişkileri
  educations            Education[]            @relation("UserEducations")
  internshipPreferences InternshipPreferences? @relation("UserPreferences")
  skills                Skills?                @relation("UserSkills")
  experiences           Experience[]           @relation("UserExperiences")
  documents             Documents?             @relation("UserDocuments")
  references            Reference[]            @relation("UserReferences")

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model JobPosting {
  id           String        @id @default(uuid())
  title        String
  description  String
  companyId    String
  company      Company       @relation("CompanyJobs", fields: [companyId], references: [id], onDelete: Cascade)
  applications Application[] @relation("JobApplications")
  status       String        @default("ACTIVE")
  startDate    DateTime?
  endDate      DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Application {
  id           String     @id @default(uuid())
  candidateId  String
  candidate    User       @relation("CandidateApplications", fields: [candidateId], references: [id], onDelete: Cascade)
  jobPostingId String
  jobPosting   JobPosting @relation("JobApplications", fields: [jobPostingId], references: [id], onDelete: Cascade)
  cvUrl        String
  status       String     @default("PENDING")
  techScore    Int?
  reliability  Int?
  interviewScore Int?
  overallScore   Int?
  interviewId  String?
  interviewPassword String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model HRSettings {
  id                         String   @id @default(uuid())
  companyId                  String   @unique
  company                    Company  @relation("CompanySettings", fields: [companyId], references: [id], onDelete: Cascade)
  stage1AutoProceedThreshold Int      @default(75)
  stage1AutoRejectThreshold  Int      @default(50)
  stage2AutoInviteThreshold  Int      @default(75)
  stage2AutoRejectThreshold  Int      @default(60)
  stage3AutoProceedThreshold Int      @default(75)
  stage3AutoRejectThreshold  Int      @default(50)
  stage4AutoHireThreshold    Int      @default(80)
  stage4AutoRejectThreshold  Int      @default(50)
  autoApproveJobs            Boolean  @default(true)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model Education {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation("UserEducations", fields: [userId], references: [id], onDelete: Cascade)
  university     String
  faculty        String
  degree         String
  year           String
  gpa            String
  startDate      DateTime
  endDate        DateTime?
  isHighSchool   Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model InternshipPreferences {
  id             String    @id @default(uuid())
  userId         String    @unique
  user           User      @relation("UserPreferences", fields: [userId], references: [id], onDelete: Cascade)
  type           String
  duration       Int
  insurance      String
  workModel      String
  availability   String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Skills {
  id               String    @id @default(uuid())
  userId           String    @unique
  user             User      @relation("UserSkills", fields: [userId], references: [id], onDelete: Cascade)
  foreignLanguages String
  technicalSkills  String
  softSkills       String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Experience {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation("UserExperiences", fields: [userId], references: [id], onDelete: Cascade)
  type           String
  title          String
  organization   String
  description    String?
  startDate      DateTime?
  endDate        DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Documents {
  id             String    @id @default(uuid())
  userId         String    @unique
  user           User      @relation("UserDocuments", fields: [userId], references: [id], onDelete: Cascade)
  cvUrl          String
  transcriptUrl  String?
  linkedInUrl    String?
  githubUrl      String?
  portfolioUrl   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Reference {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation("UserReferences", fields: [userId], references: [id], onDelete: Cascade)
  name             String
  title            String
  institution      String
  contact          String
  motivationLetter String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}
