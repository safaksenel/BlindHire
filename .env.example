# ==========================================
# AgenticHR (BlindHire) Environment Variables
# ==========================================

# 1. Database Configuration (Prisma)
# SQLite is used by default. Point to a local .db file.
DATABASE_URL="file:./dev.db"

# 2. Email / SMTP Configuration (Nodemailer)
# Used for sending interview invitations and notifications.
# If using Gmail, use an "App Password", NOT your actual login password.
SMTP_EMAIL="your_email@gmail.com"
SMTP_PASSWORD="your_16_char_app_password"

# 3. LLM API Keys
# GROQ is the primary engine for ATS parsing, Question Generation, and AI Agent interactions.
GROQ_API_KEY="gsk_YOUR_GROQ_API_KEY_HERE"

# 4. App URL (Optional but recommended for production)
# NEXT_PUBLIC_APP_URL="http://localhost:3000"
